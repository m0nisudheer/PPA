generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum DonorType {
  individual
  organisation
}

enum PaymentStatus {
  pending
  success
  failed
}

model Donor {
  id            String      @id @default(uuid())

  donorType     DonorType

  fullName      String
  email         String      @unique
  mobile        String

  pan           String?
  addressLine1  String?
  addressLine2  String?
  city          String?
  state         String?
  pinCode       String?

  donations     Donation[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Donation {
  id                  String          @id @default(uuid())

  donorId             String
  donor               Donor           @relation(fields: [donorId], references: [id], onDelete: Cascade)
   donorType           DonorType
  amount              Int
  title               String
  description         String

  razorpayOrderId     String          @unique
  razorpayPaymentId   String?
  razorpaySignature   String?

  paymentStatus       PaymentStatus   @default(pending)

  receipt             String?

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
}